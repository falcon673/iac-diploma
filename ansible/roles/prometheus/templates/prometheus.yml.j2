global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets: ['{{ vm1_ip }}:{{ node_exporter_port }}']
        labels:
          instance: 'vm1-command-server'
